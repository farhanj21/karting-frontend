# ---------------------------------------------------------------------------
# Copy this file to `.env.local` for local dev, and add the same variables in
# your Vercel project (Settings → Environment Variables). Never commit secrets.
# ---------------------------------------------------------------------------

# MongoDB Atlas connection string (existing — powers leaderboards + sessions)
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority"

# Clerk authentication keys — from https://dashboard.clerk.com → your app → API Keys
# The publishable key is safe to expose to the browser; the secret key is server-only.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxx"

# Where Clerk's hosted routes live in this app (these match the pages we ship).
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/my-sessions"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/my-sessions"
